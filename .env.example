# ============================================================================
# Magicmail Docker Compose 环境变量配置模板
# 复制此文件为 .env 并按需修改:  cp .env.example .env
# =============================================================================

# ─── 服务端口 ──────────────────────────────────────
MAGICMAIL_PORT=8080

# ─── 时区 ──────────────────────────────────────────
TZ=Asia/Shanghai

# ─── 资源限制（可选） ──────────────────────────────
MAGICMAIL_MEMORY_LIMIT=512M
MAGICMAIL_MEMORY_RESERVATION=128M

# ─── 以下变量可直接在此文件中取消注释生效 ──────
# 也可在 docker-compose.yml 的 environment 段添加

# # 运行模式（默认 production）
# MAGICMAIL_ENV=production

# # CORS 白名单（逗号分隔）
# MAGICMAIL_CORS_ORIGINS=https://mail.example.com,https://app.example.com

# # IMAP 同步间隔（秒），最低 10 秒
# MAGICMAIL_POLL_INTERVAL=300

# # IMAP 最大并发连接数
# MAGICMAIL_MAX_CONCURRENT=10

# # 启用附件自动缓存（true/false）
# MAGICMAIL_AUTO_CACHE=false

# # 附件缓存阈值（MB），小于此值立即缓存
# MAGICMAIL_CACHE_THRESHOLD=2

# # 最小保留磁盘空间（MB）
# MAGICMAIL_MIN_DISK_FREE=1024

# # 单附件大小上限（MB）
# MAGICMAIL_MAX_ATTACHMENT_SIZE=50
